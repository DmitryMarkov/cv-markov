{
  "name": "cv-markov",
  "version": "3.2.1",
  "author": "Dmitry Markov",
  "description": "Dmitry Markov's CV",
  "bugs": {
    "url": "https://github.com/DmitryMarkov/cv-markov/issues"
  },
  "homepage": "https://github.com/DmitryMarkov/cv-markov#readme",
  "keywords": [
    "html",
    "css"
  ],
  "license": "ISC",
  "main": "src/index.html",
  "repository": {
    "type": "git",
    "url": "git@github.com:DmitryMarkov/cv-markov.git"
  },
  "scripts": {
    "build": "vite build",
    "css": "stylelint src/**/*.css",
    "css:fix": "stylelint src/**/*.css --fix",
    "editorconfig": "editorconfig-checker",
    "html": "html-validate src/index.html",
    "markdown": "remark CHANGELOG.md README.md TODO.md",
    "prepare": "husky",
    "prettier": "prettier ./src/** src/index.html",
    "prettier:fix": "prettier --write ./src/** src/index.html",
    "preview": "vite preview --port 4444",
    "security-audit": "yarn npm audit --severity critical",
    "serve": "vite",
    "start": "yarn serve",
    "test": "yarn build && mocha test/index.js --timeout 15000",
    "test:update": "yarn build && node test/update.js",
    "up": "yarn upgrade-interactive"
  },
  "resolutions": {
    "caniuse-lite": "^1.0.30001478"
  },
  "devDependencies": {
    "@commitlint/cli": "20.5.0",
    "@commitlint/config-conventional": "20.5.0",
    "autoprefixer": "10.5.0",
    "chai": "6.2.2",
    "cssnano": "8.0.1",
    "editorconfig-checker": "5.0.1",
    "html-validate": "10.15.0",
    "husky": "9.1.7",
    "lint-staged": "13.2.3",
    "mocha": "10.8.2",
    "pixelmatch": "7.2.0",
    "pngjs": "7.0.0",
    "polyserve": "0.27.15",
    "postcss": "8.5.14",
    "prettier": "3.8.3",
    "puppeteer": "24.43.0",
    "remark-cli": "12.0.1",
    "remark-preset-lint-markdown-style-guide": "6.0.1",
    "remark-preset-lint-recommended": "7.0.1",
    "stylelint": "17.11.0",
    "stylelint-prettier": "5.0.3",
    "vite": "8.0.11",
    "vite-plugin-static-copy": "4.1.0"
  },
  "browserslist": [
    ">0.2%",
    "not dead",
    "not ie >= 0",
    "not op_mini all"
  ],
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "engines": {
    "node": ">=24"
  },
  "lint-staged": {
    "*.css": [
      "prettier --write",
      "stylelint --fix"
    ],
    "*.html": [
      "prettier --write"
    ],
    "!(CLAUDE).md": [
      "remark --quiet"
    ]
  },
  "prettier": {
    "arrowParens": "avoid",
    "trailingComma": "es5",
    "tabWidth": 2,
    "printWidth": 76,
    "semi": false,
    "singleQuote": true
  },
  "remarkConfig": {
    "plugins": [
      "preset-lint-markdown-style-guide"
    ]
  },
  "renovate": {
    "automerge": true,
    "automergeType": "branch",
    "commitMessagePrefix": "Renovate: ",
    "extends": [
      "config:recommended"
    ],
    "major": {
      "automerge": true
    }
  },
  "stylelint": {
    "extends": "stylelint-prettier/recommended",
    "rules": {
      "block-no-empty": null,
      "color-no-invalid-hex": true,
      "rule-empty-line-before": [
        "always",
        {
          "except": [
            "first-nested"
          ],
          "ignore": [
            "after-comment"
          ]
        }
      ]
    }
  },
  "packageManager": "yarn@4.14.1"
}
