{
  "name": "cv-markov",
  "version": "4.0.0",
  "author": "Dmitry Markov",
  "description": "Dmitry Markov's CV",
  "bugs": {
    "url": "https://github.com/DmitryMarkov/cv-markov/issues"
  },
  "homepage": "https://github.com/DmitryMarkov/cv-markov#readme",
  "keywords": [
    "html",
    "css"
  ],
  "license": "ISC",
  "main": "src/index.html",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git@github.com:DmitryMarkov/cv-markov.git"
  },
  "scripts": {
    "build": "vite build",
    "build:favicons": "node scripts/generate-favicons.mjs",
    "css": "stylelint src/**/*.css",
    "css:fix": "stylelint src/**/*.css --fix",
    "editorconfig": "editorconfig-checker",
    "html": "html-validate src/index.html",
    "markdown": "remark CHANGELOG.md README.md TODO.md",
    "prepare": "husky",
    "prettier": "prettier ./src/** src/index.html",
    "prettier:fix": "prettier --write ./src/** src/index.html",
    "preview": "vite preview --host 127.0.0.1 --port 4444",
    "security-audit": "yarn npm audit --severity critical",
    "serve": "vite",
    "start": "yarn serve",
    "test": "HOST_UID=$(id -u) HOST_GID=$(id -g) docker compose run --rm test",
    "test:run": "playwright test",
    "test:update": "TEST_FLAGS=--update-snapshots HOST_UID=$(id -u) HOST_GID=$(id -g) docker compose run --rm test",
    "up": "yarn upgrade-interactive"
  },
  "resolutions": {
    "caniuse-lite": "^1.0.30001478"
  },
  "dependenciesMeta": {
    "sharp": {
      "built": true
    }
  },
  "devDependencies": {
    "@commitlint/cli": "21.0.1",
    "@commitlint/config-conventional": "21.0.1",
    "@playwright/test": "1.60.0",
    "autoprefixer": "10.5.0",
    "cssnano": "8.0.1",
    "editorconfig-checker": "6.1.1",
    "favicons": "7.2.0",
    "html-validate": "10.17.0",
    "husky": "9.1.7",
    "lint-staged": "17.0.4",
    "postcss": "8.5.14",
    "prettier": "3.8.3",
    "remark-cli": "12.0.1",
    "remark-preset-lint-markdown-style-guide": "6.0.1",
    "remark-preset-lint-recommended": "7.0.1",
    "stylelint": "17.11.1",
    "stylelint-prettier": "5.0.3",
    "vite": "8.0.13",
    "vite-plugin-static-copy": "4.1.0"
  },
  "browserslist": [
    "defaults",
    "not op_mini all"
  ],
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "engines": {
    "node": ">=24"
  },
  "lint-staged": {
    "*.css": [
      "prettier --write",
      "stylelint --fix"
    ],
    "*.html": [
      "prettier --write"
    ],
    "!(CLAUDE).md": [
      "remark --quiet"
    ]
  },
  "prettier": {
    "arrowParens": "avoid",
    "trailingComma": "es5",
    "tabWidth": 2,
    "printWidth": 76,
    "semi": false,
    "singleQuote": true
  },
  "remarkConfig": {
    "plugins": [
      "preset-lint-markdown-style-guide"
    ]
  },
  "renovate": {
    "automerge": true,
    "automergeType": "branch",
    "commitMessagePrefix": "Renovate: ",
    "extends": [
      "config:recommended"
    ],
    "major": {
      "automerge": false
    },
    "packageRules": [
      {
        "groupName": "playwright",
        "groupSlug": "playwright",
        "matchPackageNames": [
          "@playwright/test",
          "mcr.microsoft.com/playwright"
        ]
      },
      {
        "matchPackageNames": [
          "mcr.microsoft.com/playwright"
        ],
        "versioning": "regex:^v(?<major>\\d+)\\.(?<minor>\\d+)\\.(?<patch>\\d+)-noble$"
      }
    ]
  },
  "stylelint": {
    "extends": "stylelint-prettier/recommended",
    "rules": {
      "block-no-empty": null,
      "color-no-invalid-hex": true,
      "rule-empty-line-before": [
        "always",
        {
          "except": [
            "first-nested"
          ],
          "ignore": [
            "after-comment"
          ]
        }
      ]
    }
  },
  "packageManager": "yarn@4.14.1"
}
